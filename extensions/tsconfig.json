{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@mariozechner/pi-coding-agent": ["./fleet/node_modules/@mariozechner/pi-coding-agent"],
      "@sbluemin/unified-agent": ["../packages/unified-agent"]
    }
  },
  "include": ["**/*.ts"]
}
